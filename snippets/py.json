{
    "main": {
        "prefix": "main",
        "body": [
            "if __name__ == '__main__':",
            "\t${1:main()}"
        ],
        "description": "Standard Python entry point"
    },
    "def function": {
        "prefix": "def",
        "body": [
            "def ${1:func_name}(${2:args}) -> ${3:None}:",
            "\t\"\"\"${4:docstring}\"\"\"",
            "\t$0"
        ],
        "description": "Define a function with type hints and docstring"
    },
    "class basic": {
        "prefix": "class",
        "body": [
            "class ${1:ClassName}:",
            "\t\"\"\"${2:Class description}\"\"\"",
            "",
            "\tdef __init__(self, ${3:args}):",
            "\t\t${4:pass}",
            "\t\t$0"
        ],
        "description": "Define a basic class with an __init__ method"
    },
    "dataclass": {
        "prefix": "dataclass",
        "body": [
            "from dataclasses import dataclass",
            "",
            "@dataclass",
            "class ${1:ClassName}:",
            "\t${2:field}: ${3:str}",
            "\t$0"
        ],
        "description": "Define a dataclass"
    },
    "try/except block": {
        "prefix": "try",
        "body": [
            "try:",
            "\t${1:pass}",
            "except ${2:Exception} as ${3:e}:",
            "\t${4:print(f'Error: {e}')}",
            "\t$0"
        ],
        "description": "Try/Except block for error handling"
    },
    "with open file": {
        "prefix": "with",
        "body": [
            "with open(${1:'filepath'}, '${2:r}') as ${3:f}:",
            "\t${4:content} = ${3:f}.read()",
            "\t$0"
        ],
        "description": "With open context manager for files"
    },
    "list comprehension": {
        "prefix": "lc",
        "body": [
            "[${1:item} for ${2:item} in ${3:iterable} if ${4:condition}]"
        ],
        "description": "List comprehension syntax"
    },
    "dict comprehension": {
        "prefix": "dc",
        "body": [
            "{${1:k}: ${2:v} for ${3:k, v} in ${4:iterable}.items()}"
        ],
        "description": "Dictionary comprehension syntax"
    },
    "__init__ method": {
        "prefix": "init",
        "body": [
            "def __init__(self, ${1:args}):",
            "\t${2:super().__init__()}",
            "\t$0"
        ],
        "description": "Define __init__ method"
    },
    "logging setup": {
        "prefix": "log",
        "body": [
            "import logging",
            "logger = logging.getLogger(__name__)",
            "logging.basicConfig(level=logging.${1:INFO})"
        ],
        "description": "Initialize standard python logging"
    }
}
